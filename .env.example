# ==============================================================================
# .env.example - DockFlareStack Template (NGUON SU THAT DUY NHAT cho env)
# ------------------------------------------------------------------------------
# !!! QUAN TRONG - CACH DUNG:
#  - File nay chua PLACEHOLDER dang ${VAR}. Docker Compose KHONG tu expand bien
#    ben trong file .env, Node dotenv cung khong. Vi vay:
#    => `bootstrap.mjs` se RESOLVE moi ${VAR} roi GHI RA `.env.resolved`, va
#       `docker compose --env-file .env.resolved`. KHONG cho compose doc file nay
#       truc tiep (neu khong DOCKFLARE_TUNNEL_NAME se nhan literal "${STACK_ID}").
#  - Copy file nay thanh .env, dien gia tri, roi chay bootstrap.
#
# Quy uoc:
#  - Prefix theo dich vu de tranh xung dot.
#  - MARKER base64: secret CO THE dat prefix `base64:` (vd `base64:eyJ...`).
#    Khong co prefix -> RAW. Sau decode validate theo ngu canh.
#  - Path ben vung derive tu DOCKER_VOLUMES_DIR (bootstrap resolve).
#  - KHONG commit file .env that.
# ==============================================================================

# ------------------------------------------------------------------------------
# CHUNG / CORE
# ------------------------------------------------------------------------------
DOCKER_VOLUMES_DIR=.docker-volumes
DOCKER_BUILDKIT=1
# !!! BAT BUOC DOI. Dinh danh stack duy nhat (tach lock/tunnel/remote). Bootstrap
# exit non-zero neu con CHANGE_ME ma bat module dung RTDB/remote chung.
STACK_ID=CHANGE_ME

# ------------------------------------------------------------------------------
# DOMAIN (QUAN TRONG NHAT - de expose app/service ra internet qua Cloudflare Tunnel)
# ------------------------------------------------------------------------------
# !!! BAT BUOC. Domain goc ban da add vao Cloudflare (zone). Vd: example.com
# Moi service se co hostname dang <sub>.<DOMAIN>. Domain nay PHAI:
#   - Da duoc add vao Cloudflare account (co Zone).
#   - Token DOCKFLARE_CF_API_TOKEN co quyen Zone DNS + Account Tunnel tren domain nay.
DOMAIN=CHANGE_ME.example.com
# Subdomain cho tung service (ghep voi DOMAIN thanh hostname day du).
# De trong service nao thi service do KHONG duoc expose ra ngoai (chi noi bo).
# DockFlare UI (dashboard quan ly tunnel).
DOCKFLARE_SUBDOMAIN=dockflare
DOCKFLARE_HOSTNAME=${DOCKFLARE_SUBDOMAIN}.${DOMAIN}
# Dozzle (log viewer).
DOZZLE_SUBDOMAIN=logs
DOZZLE_HOSTNAME=${DOZZLE_SUBDOMAIN}.${DOMAIN}
# Filebrowser (quan ly file).
FILEBROWSER_SUBDOMAIN=files
FILEBROWSER_HOSTNAME=${FILEBROWSER_SUBDOMAIN}.${DOMAIN}
# ttyd (WebSSH).
TTYD_SUBDOMAIN=ssh
TTYD_HOSTNAME=${TTYD_SUBDOMAIN}.${DOMAIN}
# Zero Trust Access: bat de chan truy cap public (khuyen nghi cho ttyd/filebrowser).
# Chon: true | false. Mac dinh: true (bao ve bang Cloudflare Access).
ACCESS_PROTECT=true
# Email/domain duoc phep qua Access (danh sach cach nhau dau phay). Vd: you@gmail.com
ACCESS_ALLOWED_EMAILS=

# ------------------------------------------------------------------------------
# DOCKFLARE (core - luon bat)
# ------------------------------------------------------------------------------
# Cloudflare API token (scoped: Zone.DNS + Account.Tunnel + Access). Uu tien scoped.
# Health-check: GET /client/v4/user/tokens/verify (Bearer) -> result.status==active.
# Lay tai: Cloudflare dashboard > My Profile > API Tokens.
DOCKFLARE_CF_API_TOKEN=
# Account ID. De trong -> resolve.mjs tu resolve tu token va cache.
DOCKFLARE_CF_ACCOUNT_ID=
# Ten tunnel - derive tu STACK_ID. 2 stack PHAI khac ten.
DOCKFLARE_TUNNEL_NAME=${STACK_ID}
DOCKFLARE_LOG_LEVEL=info
# Redis event bus (multi-host). bootstrap ep =true khi COORDINATOR_ENABLE=true.
DOCKFLARE_REDIS_ENABLE=false
DOCKFLARE_REDIS_URL=
DOCKFLARE_REDIS_HOST=redis
DOCKFLARE_REDIS_PORT=6379
DOCKFLARE_REDIS_PASSWORD=

# ------------------------------------------------------------------------------
# RESOLVE / RTDB (config & cache - luon bat)
# ------------------------------------------------------------------------------
RTDB_URL=
# Service account JSON Firebase. Co the `base64:<chuoi>` hoac raw JSON.
RTDB_SERVICE_ACCOUNT=
RESOLVE_CACHE_PATH=${DOCKER_VOLUMES_DIR}/.cache/resolve.json
RESOLVE_RTDB_PATH=/stack/${STACK_ID}/resolve-cache

# ------------------------------------------------------------------------------
# COORDINATOR (tuy chon - lifecycle handover chong restart 60 phut)
# ------------------------------------------------------------------------------
COORDINATOR_ENABLE=false
COORDINATOR_LOCK_PATH=/stack/${STACK_ID}/coordinator
COORDINATOR_HEARTBEAT_SEC=15
COORDINATOR_SESSION_TTL_SEC=60
COORDINATOR_HANDOVER_BUFFER_SEC=600
COORDINATOR_OLD_AUTO_EXIT=false
COORDINATOR_MAX_OVERLAP=2
COORDINATOR_READONLY_FLAG_PATH=${DOCKER_VOLUMES_DIR}/.readonly

# ------------------------------------------------------------------------------
# RCLONE (tuy chon - sync bulk .docker-volumes)
# ------------------------------------------------------------------------------
RCLONE_ENABLE=false
RCLONE_CONFIG_PATH=
RCLONE_CONFIG_CONTENT=
RCLONE_REMOTE=
RCLONE_PATH=${STACK_ID}
RCLONE_TRANSFERS=4
RCLONE_CHECKERS=4
# bootstrap TU SINH tu LITESTREAM_DB_PATH. De trong.
RCLONE_EXCLUDE=

# ------------------------------------------------------------------------------
# LITESTREAM (tuy chon - SQLite realtime -> S3 Supabase)
# ------------------------------------------------------------------------------
LITESTREAM_ENABLE=false
LITESTREAM_S3_ENDPOINT=
LITESTREAM_S3_BUCKET=
LITESTREAM_S3_ACCESS_KEY_ID=
LITESTREAM_S3_SECRET_ACCESS_KEY=
LITESTREAM_DB_PATH=${DOCKER_VOLUMES_DIR}/app.db

# ------------------------------------------------------------------------------
# TAILSCALE (tuy chon - mang noi bo)
# ------------------------------------------------------------------------------
TAILSCALE_ENABLE=false
TAILSCALE_CLIENT_ID=
TAILSCALE_CLIENT_SECRET=
TAILSCALE_TAGS=tag:container
TAILSCALE_EPHEMERAL=true
TAILSCALE_STATE_DIR=${DOCKER_VOLUMES_DIR}/tailscale

# ------------------------------------------------------------------------------
# DOZZLE (tuy chon - log viewer) - MODULE BAO MAT (fail-closed)
# ------------------------------------------------------------------------------
DOZZLE_ENABLE=false
DOZZLE_ADDR=:8080
DOZZLE_BASE=/
# simple can users.yml (bootstrap sinh bang `dozzle generate`). FAIL-CLOSED.
DOZZLE_AUTH_PROVIDER=simple
DOZZLE_USERNAME=admin
DOZZLE_PASSWORD=
DOZZLE_LEVEL=info
DOZZLE_NO_ANALYTICS=1

# ------------------------------------------------------------------------------
# FILEBROWSER (tuy chon) - MODULE BAO MAT (fail-closed)
# ------------------------------------------------------------------------------
# image doc FB_* - compose map tuong minh FB_PORT=${FILEBROWSER_PORT}...
FILEBROWSER_ENABLE=false
FILEBROWSER_PORT=8081
# THU MUC GOC TRONG CONTAINER (khong phai host). Bind host do compose volumes:.
FILEBROWSER_ROOT=/srv
FILEBROWSER_BASEURL=
# Password admin bat buoc (bootstrap set qua CLI). FAIL-CLOSED neu rong.
FILEBROWSER_ADMIN_PASSWORD=

# ------------------------------------------------------------------------------
# TTYD / WEBSSH (tuy chon) - MODULE BAO MAT (fail-closed)
# ------------------------------------------------------------------------------
# CLI args, entrypoint dung tokenizer. FAIL-CLOSED neu thieu credential.
TTYD_ENABLE=false
TTYD_PORT=7681
# Basic auth user:pass. BAT BUOC neu ENABLE. Vd: admin:changeme
TTYD_CREDENTIAL=
# Writable -> arg -W. Mac dinh true (WebSSH tuong tac that).
TTYD_WRITABLE=true
TTYD_CMD=bash
TTYD_MAX_CLIENTS=1
