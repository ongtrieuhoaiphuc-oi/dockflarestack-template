# ==============================================================================
# .env.example - DockFlareStack Template
# ------------------------------------------------------------------------------
# Quy uoc:
#  - Prefix theo dich vu de tranh xung dot.
#  - Moi env co gia tri mac dinh hop ly; tuy chinh lai theo nhu cau.
#  - Gia tri chon (enum) da liet ke day du trong comment.
#  - Fallback Base64 -> RAW: co the dat gia tri base64, he thong tu decode; neu
#    khong phai base64 hop le thi dung nguyen (RAW). LUU Y: sau decode co
#    VALIDATE THEO NGU CANH (vd service account phai JSON.parse duoc) moi chap
#    nhan, tranh secret dang token vo tinh "decode duoc" ra rac.
#  - Moi path ben vung deu derive tu DOCKER_VOLUMES_DIR (KHONG hardcode rieng le).
#  - CANH BAO TEMPLATE: STACK_ID / DOCKFLARE_TUNNEL_NAME / RCLONE_PATH KHONG duoc
#    de nguyen default khi nhieu stack cung share RTDB / Cloudflare / rclone remote.
#    Doi chung theo ngu canh (vd ten repo) truoc khi bat module dung tai nguyen chung.
#  - KHONG commit file .env that (chi commit file .env.example nay).
# ==============================================================================

# ------------------------------------------------------------------------------
# CHUNG / CORE
# ------------------------------------------------------------------------------
# Thu muc data chung cho tat ca app va docker volumes. Configurable.
# Moi path con (cache, sqlite, tailscale state) deu tham chieu bien nay.
DOCKER_VOLUMES_DIR=.docker-volumes
# Bat BuildKit cho docker build (1 = bat). Nen de 1.
DOCKER_BUILDKIT=1
# Dinh danh stack - PHAI DUY NHAT theo tung deploy. Dung de tach lock coordinator,
# tach namespace RTDB, tranh dung do khi nhieu stack cung share 1 Firebase RTDB.
# KHUYEN NGHI: dat theo ten repo (vd ${GITHUB_REPOSITORY}) hoac ten project rieng.
# KHONG de nguyen gia tri vi du duoi neu ban deploy nhieu stack chung tai nguyen.
STACK_ID=CHANGE_ME_unique_stack_id

# ------------------------------------------------------------------------------
# DOCKFLARE (core - luon bat)
# ------------------------------------------------------------------------------
# Cloudflare API token (scoped: Zone + Account + Tunnel). Uu tien token scoped
# thay vi global API key. Lay tai: Cloudflare dashboard > My Profile > API Tokens.
DOCKFLARE_CF_API_TOKEN=
# Account ID cua Cloudflare. Neu de trong, resolve.mjs se tu resolve tu email +
# global key va cache lai. Lay tai: Cloudflare dashboard > trang chu > Account ID.
DOCKFLARE_CF_ACCOUNT_ID=
# Ten tunnel - PHAI DUY NHAT theo tung stack. 2 stack cung ten tunnel -> Cloudflare
# route lan lon hostname. Khuyen nghi derive theo STACK_ID.
DOCKFLARE_TUNNEL_NAME=CHANGE_ME_unique_tunnel
# Log level. Chon: debug | info | warn | error. Mac dinh: info.
DOCKFLARE_LOG_LEVEL=info
# Bat Redis event bus (dung cho multi-host). Chon: true | false. Mac dinh: false.
DOCKFLARE_REDIS_ENABLE=false
# Ket noi Redis khi bat multi-host. Uu tien URL day du; hoac dung HOST/PORT.
# Vd URL: redis://:password@redis-host:6379/0
DOCKFLARE_REDIS_URL=
DOCKFLARE_REDIS_HOST=redis
DOCKFLARE_REDIS_PORT=6379
DOCKFLARE_REDIS_PASSWORD=

# ------------------------------------------------------------------------------
# RESOLVE / RTDB (config & cache - luon bat)
# ------------------------------------------------------------------------------
# URL cua Google Realtime Database. Vd: https://<project>.firebaseio.com
RTDB_URL=
# Service account JSON cua Firebase (base64 hoac raw JSON). Sau decode phai
# JSON.parse duoc moi chap nhan. Lay tai: Firebase console > Project settings >
# Service accounts > Generate new private key.
RTDB_SERVICE_ACCOUNT=
# Namespace RTDB tach biet theo nghiep vu (KHONG dung chung root):
#   /stack/${STACK_ID}/coordinator/...   (lock, heartbeat, handoff)
#   /stack/${STACK_ID}/resolve-cache/... (accountId, key pool status)
RTDB_COORDINATOR_PATH=/stack/${STACK_ID}/coordinator
RTDB_RESOLVE_CACHE_PATH=/stack/${STACK_ID}/resolve-cache
# Duong dan file cache local cho resolve. Derive tu DOCKER_VOLUMES_DIR.
RESOLVE_CACHE_PATH=${DOCKER_VOLUMES_DIR}/.cache/resolve.json

# ------------------------------------------------------------------------------
# COORDINATOR (tuy chon - lifecycle handover chong restart 60 phut)
# ------------------------------------------------------------------------------
# Bat coordinator. Chon: true | false. Mac dinh: false.
COORDINATOR_ENABLE=false
# Node lock tren RTDB. Mac dinh derive theo RTDB_COORDINATOR_PATH (theo STACK_ID)
# de tranh dung do giua cac stack cung share RTDB.
COORDINATOR_LOCK_PATH=${RTDB_COORDINATOR_PATH}
# Chu ky heartbeat (giay). Nen < 1/3 SESSION_TTL. Mac dinh: 15.
COORDINATOR_HEARTBEAT_SEC=15
# TTL cua phien primary (giay). Mac dinh: 60.
COORDINATOR_SESSION_TTL_SEC=60
# Buffer kich hoat handover som truoc deadline job (giay). Vd job 60 phut, buffer
# 600 => bat dau handover o phut 50 de flush kip truoc khi runner SIGKILL.
COORDINATOR_HANDOVER_BUFFER_SEC=600
# Instance cu tu thoat khi cai moi ready (thay vi chi read-only).
# Chon: true | false. Mac dinh: false (read-only).
# CANH BAO: neu de false, node Tailscale ephemeral cua instance cu van song
# (ephemeral chi don khi container thuc su thoat) -> tich tu qua nhieu chu ky
# handover. Nen dat gioi han so instance overlap toi da (COORDINATOR_MAX_OVERLAP).
COORDINATOR_OLD_AUTO_EXIT=false
# Gioi han so instance overlap toi da khi AUTO_EXIT=false. Mac dinh: 2.
COORDINATOR_MAX_OVERLAP=2

# ------------------------------------------------------------------------------
# RCLONE (tuy chon - sync bulk .docker-volumes)
# ------------------------------------------------------------------------------
# Bat rclone. Chon: true | false. Mac dinh: false.
RCLONE_ENABLE=false
# Cau hinh rclone: DUNG 1 TRONG 2 (khong gop chung de tranh nham path/content).
#  - RCLONE_CONFIG_PATH: duong dan toi file rclone.conf co san (uu tien neu co).
#  - RCLONE_CONFIG_CONTENT: noi dung rclone.conf (base64 hoac raw), se ghi ra file tam.
# Lay bang: rclone config.
RCLONE_CONFIG_PATH=
RCLONE_CONFIG_CONTENT=
# Ten remote va path dich - PATH PHAI DUY NHAT theo stack. 2 stack cung path ->
# ghi de volume cua nhau. Khuyen nghi derive theo STACK_ID.
RCLONE_REMOTE=
RCLONE_PATH=CHANGE_ME_unique_path
# So luong transfer/checker song song. Mac dinh: 4.
RCLONE_TRANSFERS=4
RCLONE_CHECKERS=4
# Loai tru SQLite khoi rclone sync (litestream so huu SQLite). Mac dinh tu suy ra
# tu LITESTREAM_DB_PATH + -wal/-shm. Co the them pattern khac, cach nhau bang dau phay.
RCLONE_EXCLUDE=**/app.db,**/app.db-wal,**/app.db-shm

# ------------------------------------------------------------------------------
# LITESTREAM (tuy chon - SQLite realtime -> S3 Supabase)
# ------------------------------------------------------------------------------
# Bat litestream. Chon: true | false. Mac dinh: false.
# NGUYEN TAC: litestream so huu file SQLite, rclone so huu phan con lai.
# rclone PHAI --exclude path nay + -wal/-shm de tranh corrupt.
LITESTREAM_ENABLE=false
# Endpoint S3 cua Supabase. Lay tu credential supabase.com.database (phan S3Url).
LITESTREAM_S3_ENDPOINT=
# Ten bucket.
LITESTREAM_S3_BUCKET=
# Access key va secret. Lay tu supabase.com.database (AccessKeyID|SecretAccessKey).
LITESTREAM_S3_ACCESS_KEY_ID=
LITESTREAM_S3_SECRET_ACCESS_KEY=
# Duong dan file SQLite can replicate. Derive tu DOCKER_VOLUMES_DIR.
LITESTREAM_DB_PATH=${DOCKER_VOLUMES_DIR}/app.db

# ------------------------------------------------------------------------------
# TAILSCALE (tuy chon - mang noi bo)
# ------------------------------------------------------------------------------
# Bat tailscale. Chon: true | false. Mac dinh: false.
TAILSCALE_ENABLE=false
# OAuth client (tu tailscale.com.TrustCredentials). Adapter se dung cap nay goi
# API lay ephemeral authkey roi set TS_AUTHKEY cho image. Lay tai: Tailscale
# admin > Settings > OAuth clients.
TAILSCALE_CLIENT_ID=
TAILSCALE_CLIENT_SECRET=
# Tags advertise (bat buoc khi dung OAuth). Adapter dich sang
# TS_EXTRA_ARGS=--advertise-tags=<gia tri>. Vd: tag:container
TAILSCALE_TAGS=tag:container
# Dung node ephemeral (tu don khi thoat). Chon: true | false. Mac dinh: true.
TAILSCALE_EPHEMERAL=true
# State dir. Derive tu DOCKER_VOLUMES_DIR. Adapter map sang TS_STATE_DIR.
TAILSCALE_STATE_DIR=${DOCKER_VOLUMES_DIR}/tailscale

# ------------------------------------------------------------------------------
# DOZZLE (tuy chon - log viewer realtime) - MODULE CO BE MAT BAO MAT
# ------------------------------------------------------------------------------
# Bat dozzle. Chon: true | false. Mac dinh: false.
DOZZLE_ENABLE=false
# Dia chi bind (image doc thang). Mac dinh: :8080
DOZZLE_ADDR=:8080
# Base path khi sau reverse proxy. Mac dinh: /
DOZZLE_BASE=/
# Auth provider. Chon: none | simple. Mac dinh: simple.
# FAIL-CLOSED: neu expose ma de none -> container khong start (tranh public khong auth).
DOZZLE_AUTH_PROVIDER=simple
# Log level. Chon: debug | info | warn | error. Mac dinh: info.
DOZZLE_LEVEL=info
# Tat analytics. Chon: 0 | 1. Mac dinh: 1.
DOZZLE_NO_ANALYTICS=1

# ------------------------------------------------------------------------------
# FILEBROWSER (tuy chon - quan ly file volume qua web) - MODULE CO BE MAT BAO MAT
# ------------------------------------------------------------------------------
# LUU Y: image doc bien FB_* - compose PHAI map tuong minh FB_PORT=${FILEBROWSER_PORT}
# ... neu khong container se silent-fail dung default sai.
# Bat filebrowser. Chon: true | false. Mac dinh: false.
FILEBROWSER_ENABLE=false
# Cong lang nghe -> map sang FB_PORT. Mac dinh: 8081.
FILEBROWSER_PORT=8081
# Thu muc goc phuc vu - LA PATH BEN TRONG CONTAINER (-> FB_ROOT), KHONG phai path host.
# Viec bind ${DOCKER_VOLUMES_DIR} vao container do compose volumes: quyet dinh,
# KHONG qua bien nay. Mac dinh: /srv
FILEBROWSER_ROOT=/srv
# Base URL khi sau reverse proxy -> map sang FB_BASEURL. De trong neu khong dung.
FILEBROWSER_BASEURL=

# ------------------------------------------------------------------------------
# TTYD / WEBSSH (tuy chon - terminal web vao host runner) - MODULE CO BE MAT BAO MAT
# ------------------------------------------------------------------------------
# LUU Y: ttyd cau hinh bang CLI args, KHONG phai env. Entrypoint wrapper dung
# mang args tu cac bien duoi (escape ky, tranh injection).
# Bat ttyd. Chon: true | false. Mac dinh: false.
TTYD_ENABLE=false
# Cong lang nghe -> arg -p. Mac dinh: 7681.
TTYD_PORT=7681
# Basic auth dang user:pass -> arg -c. FAIL-CLOSED: thieu bien nay ma TTYD_ENABLE=true
# thi container KHONG start (khong chay terminal khong auth). Vd: admin:changeme
TTYD_CREDENTIAL=
# Cho phep ghi -> arg -W. Chon: true | false. Mac dinh: true (WebSSH tuong tac that;
# neu false thi khong go duoc lenh, smoke test whoami se fail). De false chi khi
# use-case la xem thu dong.
TTYD_WRITABLE=true
# Lenh chay trong terminal. Vd: bash | sh | ssh user@host. Mac dinh: bash.
TTYD_CMD=bash
# Gioi han so client dong thoi -> arg --max-clients. Mac dinh: 1.
TTYD_MAX_CLIENTS=1
