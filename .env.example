# DockFlareStack Template. Copy thanh .env, khong commit secret.
DOCKER_VOLUMES_DIR=.docker-volumes
DOCKER_BUILDKIT=1
STACK_ID=CHANGE_ME
DOMAIN=CHANGE_ME.example.com
DOCKFLARE_SUBDOMAIN=dockflare
DOCKFLARE_HOSTNAME=${DOCKFLARE_SUBDOMAIN}.${DOMAIN}
DOZZLE_SUBDOMAIN=logs
DOZZLE_HOSTNAME=${DOZZLE_SUBDOMAIN}.${DOMAIN}
FILEBROWSER_SUBDOMAIN=files
FILEBROWSER_HOSTNAME=${FILEBROWSER_SUBDOMAIN}.${DOMAIN}
TTYD_SUBDOMAIN=ssh
TTYD_HOSTNAME=${TTYD_SUBDOMAIN}.${DOMAIN}
ACCESS_PROTECT=true
ACCESS_ALLOWED_EMAILS=

# Cloudflare credential priority:
# 1) Neu DOCKFLARE_CF_API_TOKEN co gia tri: giu nguyen, KHONG tao token moi.
# 2) Neu token rong: bat buoc EMAIL + GLOBAL_APIKEY. Bootstrap verify global key,
#    resolve Account ID + Zone ID, roi tao scoped API token tam thoi cho DockFlare.
# Account/Zone ID da dien thi giu nguyen; de trong thi resolve va cache (khong nhay cam).
# Token sinh ra CHI nam trong .env.resolved cua run, tuyet doi khong cache/commit.
DOCKFLARE_CF_API_TOKEN=
DOCKFLARE_CF_ACCOUNT_ID=
DOCKFLARE_CF_ZONE_ID=
DOCKFLARE_CF_EMAIL=
DOCKFLARE_CF_GLOBAL_APIKEY=
DOCKFLARE_TUNNEL_NAME=${STACK_ID}
DOCKFLARE_LOG_LEVEL=info
DOCKFLARE_REDIS_ENABLE=false
DOCKFLARE_REDIS_URL=
DOCKFLARE_REDIS_HOST=redis
DOCKFLARE_REDIS_PORT=6379
DOCKFLARE_REDIS_PASSWORD=

RTDB_URL=
RTDB_SERVICE_ACCOUNT=
RESOLVE_CACHE_PATH=${DOCKER_VOLUMES_DIR}/.cache/resolve.json
RESOLVE_RTDB_PATH=/stack/${STACK_ID}/resolve-cache
COORDINATOR_ENABLE=false
COORDINATOR_LOCK_PATH=/stack/${STACK_ID}/coordinator
COORDINATOR_HEARTBEAT_SEC=15
COORDINATOR_SESSION_TTL_SEC=60
COORDINATOR_HANDOVER_BUFFER_SEC=600
COORDINATOR_OLD_AUTO_EXIT=false
COORDINATOR_MAX_OVERLAP=2
COORDINATOR_READONLY_FLAG_PATH=${DOCKER_VOLUMES_DIR}/.readonly
RCLONE_ENABLE=false
RCLONE_CONFIG_PATH=
RCLONE_CONFIG_CONTENT=
RCLONE_REMOTE=
RCLONE_PATH=${STACK_ID}
RCLONE_TRANSFERS=4
RCLONE_CHECKERS=4
RCLONE_EXCLUDE=
LITESTREAM_ENABLE=false
LITESTREAM_S3_ENDPOINT=
LITESTREAM_S3_BUCKET=
LITESTREAM_S3_ACCESS_KEY_ID=
LITESTREAM_S3_SECRET_ACCESS_KEY=
LITESTREAM_DB_PATH=${DOCKER_VOLUMES_DIR}/app.db
TAILSCALE_ENABLE=false
TAILSCALE_CLIENT_ID=
TAILSCALE_CLIENT_SECRET=
TAILSCALE_TAGS=tag:container
TAILSCALE_EPHEMERAL=true
TAILSCALE_STATE_DIR=${DOCKER_VOLUMES_DIR}/tailscale
DOZZLE_ENABLE=false
DOZZLE_ADDR=:8080
DOZZLE_BASE=/
DOZZLE_AUTH_PROVIDER=simple
DOZZLE_USERNAME=admin
DOZZLE_PASSWORD=
DOZZLE_LEVEL=info
DOZZLE_NO_ANALYTICS=1
FILEBROWSER_ENABLE=false
FILEBROWSER_PORT=8081
FILEBROWSER_ROOT=/srv
FILEBROWSER_BASEURL=
FILEBROWSER_ADMIN_PASSWORD=
TTYD_ENABLE=false
TTYD_PORT=7681
TTYD_CREDENTIAL=
TTYD_WRITABLE=true
TTYD_CMD=bash
TTYD_MAX_CLIENTS=1
