# ==============================================================================
# .env.example - DockFlareStack Template
# ------------------------------------------------------------------------------
# Quy uoc:
#  - Prefix theo dich vu de tranh xung dot.
#  - Moi env co gia tri mac dinh hop ly; tuy chinh lai theo nhu cau.
#  - Gia tri chon (enum) da liet ke day du trong comment.
#  - Moi env ho tro fallback Base64 -> RAW: co the dat gia tri base64, he thong
#    tu decode; neu khong phai base64 hop le thi dung nguyen (RAW).
#  - KHONG commit file .env that (chi commit file .env.example nay).
# ==============================================================================

# ------------------------------------------------------------------------------
# CHUNG / CORE
# ------------------------------------------------------------------------------
# Thu muc data chung cho tat ca app va docker volumes. Configurable.
DOCKER_VOLUMES_DIR=.docker-volumes
# Bat BuildKit cho docker build (1 = bat). Nen de 1.
DOCKER_BUILDKIT=1

# ------------------------------------------------------------------------------
# DOCKFLARE (core - luon bat)
# ------------------------------------------------------------------------------
# Cloudflare API token (scoped: Zone + Account + Tunnel). Uu tien token scoped
# thay vi global API key. Lay tai: Cloudflare dashboard > My Profile > API Tokens.
DOCKFLARE_CF_API_TOKEN=
# Account ID cua Cloudflare. Neu de trong, resolve.mjs se tu resolve tu email +
# global key va cache lai. Lay tai: Cloudflare dashboard > trang chu > Account ID.
DOCKFLARE_CF_ACCOUNT_ID=
# Ten tunnel dung chung cho moi instance (de chung 1 tunnel nhieu connector).
DOCKFLARE_TUNNEL_NAME=dockflarestack
# Log level. Chon: debug | info | warn | error. Mac dinh: info.
DOCKFLARE_LOG_LEVEL=info
# Bat Redis event bus (dung cho multi-host). Chon: true | false. Mac dinh: false.
DOCKFLARE_REDIS_ENABLE=false

# ------------------------------------------------------------------------------
# RESOLVE / RTDB (config & cache - luon bat)
# ------------------------------------------------------------------------------
# URL cua Google Realtime Database. Vd: https://<project>.firebaseio.com
RTDB_URL=
# Service account JSON cua Firebase (base64 hoac raw JSON). Lay tai:
# Firebase console > Project settings > Service accounts > Generate new private key.
RTDB_SERVICE_ACCOUNT=
# Duong dan file cache local cho resolve. Mac dinh: .docker-volumes/.cache/resolve.json
RESOLVE_CACHE_PATH=.docker-volumes/.cache/resolve.json

# ------------------------------------------------------------------------------
# COORDINATOR (tuy chon - lifecycle handover chong restart 60 phut)
# ------------------------------------------------------------------------------
# Bat coordinator. Chon: true | false. Mac dinh: false.
COORDINATOR_ENABLE=false
# Duong dan node lock tren RTDB. Mac dinh: /stack/default
COORDINATOR_LOCK_PATH=/stack/default
# Chu ky heartbeat (giay). Nen < 1/3 SESSION_TTL. Mac dinh: 15.
COORDINATOR_HEARTBEAT_SEC=15
# TTL cua phien primary (giay). Mac dinh: 60.
COORDINATOR_SESSION_TTL_SEC=60
# Instance cu tu thoat khi cai moi ready (thay vi chi read-only).
# Chon: true | false. Mac dinh: false (read-only).
COORDINATOR_OLD_AUTO_EXIT=false

# ------------------------------------------------------------------------------
# RCLONE (tuy chon - sync bulk .docker-volumes)
# ------------------------------------------------------------------------------
# Bat rclone. Chon: true | false. Mac dinh: false.
RCLONE_ENABLE=false
# Noi dung/duong dan rclone.conf (base64 hoac raw). Lay bang: rclone config.
RCLONE_CONFIG=
# Ten remote va path dich. Vd remote: gdrive, path: dockflarestack
RCLONE_REMOTE=
RCLONE_PATH=dockflarestack
# So luong transfer/checker song song. Mac dinh: 4.
RCLONE_TRANSFERS=4
RCLONE_CHECKERS=4

# ------------------------------------------------------------------------------
# LITESTREAM (tuy chon - SQLite realtime -> S3 Supabase)
# ------------------------------------------------------------------------------
# Bat litestream. Chon: true | false. Mac dinh: false.
LITESTREAM_ENABLE=false
# Endpoint S3 cua Supabase. Lay tu credential supabase.com.database (phan S3Url).
LITESTREAM_S3_ENDPOINT=
# Ten bucket.
LITESTREAM_S3_BUCKET=
# Access key va secret. Lay tu supabase.com.database (AccessKeyID|SecretAccessKey).
LITESTREAM_S3_ACCESS_KEY_ID=
LITESTREAM_S3_SECRET_ACCESS_KEY=
# Duong dan file SQLite can replicate. Mac dinh: .docker-volumes/app.db
LITESTREAM_DB_PATH=.docker-volumes/app.db

# ------------------------------------------------------------------------------
# TAILSCALE (tuy chon - mang noi bo)
# ------------------------------------------------------------------------------
# Bat tailscale. Chon: true | false. Mac dinh: false.
TAILSCALE_ENABLE=false
# OAuth client (tu tailscale.com.TrustCredentials). Lay tai: Tailscale admin >
# Settings > OAuth clients.
TAILSCALE_CLIENT_ID=
TAILSCALE_CLIENT_SECRET=
# Tags advertise (bat buoc khi dung OAuth). Vd: tag:container
TAILSCALE_TAGS=tag:container
# Dung node ephemeral (tu don khi thoat). Chon: true | false. Mac dinh: true.
TAILSCALE_EPHEMERAL=true
# State dir. Mac dinh: .docker-volumes/tailscale
TAILSCALE_STATE_DIR=.docker-volumes/tailscale

# ------------------------------------------------------------------------------
# DOZZLE (tuy chon - log viewer realtime)
# ------------------------------------------------------------------------------
# Bat dozzle. Chon: true | false. Mac dinh: false.
DOZZLE_ENABLE=false
# Dia chi bind. Mac dinh: :8080
DOZZLE_ADDR=:8080
# Base path khi sau reverse proxy. Mac dinh: /
DOZZLE_BASE=/
# Auth provider. Chon: none | simple. Mac dinh: simple (nen co auth khi expose).
DOZZLE_AUTH_PROVIDER=simple
# Log level. Chon: debug | info | warn | error. Mac dinh: info.
DOZZLE_LEVEL=info
# Tat analytics. Chon: 0 | 1. Mac dinh: 1.
DOZZLE_NO_ANALYTICS=1

# ------------------------------------------------------------------------------
# FILEBROWSER (tuy chon - quan ly file volume qua web)
# ------------------------------------------------------------------------------
# Bat filebrowser. Chon: true | false. Mac dinh: false.
FILEBROWSER_ENABLE=false
# Cong lang nghe. Mac dinh: 8081.
FILEBROWSER_PORT=8081
# Thu muc goc phuc vu (nen tro vao .docker-volumes). Mac dinh: /srv
FILEBROWSER_ROOT=/srv
# Base URL khi sau reverse proxy. Mac dinh: / (de trong neu khong dung).
FILEBROWSER_BASEURL=

# ------------------------------------------------------------------------------
# TTYD / WEBSSH (tuy chon - terminal web vao host runner)
# ------------------------------------------------------------------------------
# Bat ttyd. Chon: true | false. Mac dinh: false.
TTYD_ENABLE=false
# Cong lang nghe. Mac dinh: 7681.
TTYD_PORT=7681
# Basic auth dang user:pass (BAT BUOC neu expose). Vd: admin:changeme
TTYD_CREDENTIAL=
# Cho phep ghi (writable). Chon: true | false. Mac dinh: false (read-only an toan hon).
TTYD_WRITABLE=false
# Lenh chay trong terminal. Vd: bash | sh | ssh user@host. Mac dinh: bash.
TTYD_CMD=bash
# Gioi han so client dong thoi. Mac dinh: 1.
TTYD_MAX_CLIENTS=1
