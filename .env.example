# ==============================================================================
# .env.example - DockFlareStack Template (NGUON SU THAT DUY NHAT cho env)
# ------------------------------------------------------------------------------
# !!! QUAN TRONG - CACH DUNG:
#  - File nay chua PLACEHOLDER dang ${VAR}. Docker Compose KHONG tu expand bien
#    ben trong file .env, Node dotenv cung khong. Vi vay:
#    => `bootstrap.mjs` se RESOLVE moi ${VAR} roi GHI RA `.env.resolved`, va
#       `docker compose --env-file .env.resolved`. KHONG cho compose doc file nay
#       truc tiep (neu khong DOCKFLARE_TUNNEL_NAME se nhan literal "${STACK_ID}").
#  - Copy file nay thanh .env, dien gia tri, roi chay bootstrap.
#
# Quy uoc:
#  - Prefix theo dich vu de tranh xung dot.
#  - Moi env co gia tri mac dinh hop ly; tuy chinh lai theo nhu cau.
#  - Gia tri chon (enum) da liet ke day du trong comment.
#  - MARKER base64: gia tri secret CO THE dat prefix `base64:` neu ban muon luu
#    dang base64 (vd `base64:eyJ0eXBlIjoi...`). He thong se decode phan sau prefix.
#    KHONG co prefix `base64:` -> dung nguyen RAW. (Bo auto-detect vi token thuan
#    JWT/hex vo tinh hop le base64 se bi decode nham ra rac.)
#    Sau decode van VALIDATE THEO NGU CANH (vd service account phai JSON.parse duoc).
#  - Path ben vung derive tu DOCKER_VOLUMES_DIR (bootstrap resolve).
#  - KHONG commit file .env that.
# ==============================================================================

# ------------------------------------------------------------------------------
# CHUNG / CORE
# ------------------------------------------------------------------------------
# Thu muc data chung. Moi path con tham chieu bien nay (bootstrap resolve).
DOCKER_VOLUMES_DIR=.docker-volumes
# Bat BuildKit cho docker build (1 = bat). Nen de 1.
DOCKER_BUILDKIT=1
# !!! BAT BUOC DOI khi deploy that. Dinh danh stack duy nhat, dung de tach lock
# coordinator / ten tunnel / path remote... tranh dung do khi nhieu stack share
# 1 Firebase RTDB / Cloudflare account / rclone remote.
# bootstrap.mjs: neu module dung RTDB/remote chung duoc bat ma STACK_ID con la
# CHANGE_ME (hoac rong) -> EXIT NON-ZERO (hard-block, khong chi warn).
# Co the derive tu GITHUB_REPOSITORY trong CI.
STACK_ID=CHANGE_ME

# ------------------------------------------------------------------------------
# DOCKFLARE (core - luon bat)
# ------------------------------------------------------------------------------
# Cloudflare API token (scoped: Zone + Account + Tunnel). Uu tien scoped token.
# Health-check: GET /client/v4/user/tokens/verify (Bearer) -> result.status==active.
# Lay tai: Cloudflare dashboard > My Profile > API Tokens.
DOCKFLARE_CF_API_TOKEN=
# Account ID. De trong -> resolve.mjs tu resolve tu email + global key va cache.
DOCKFLARE_CF_ACCOUNT_ID=
# Ten tunnel - derive tu STACK_ID (bootstrap resolve). 2 stack PHAI khac ten,
# neu khong Cloudflare route lan lon hostname.
DOCKFLARE_TUNNEL_NAME=${STACK_ID}
# Log level. Chon: debug | info | warn | error. Mac dinh: info.
DOCKFLARE_LOG_LEVEL=info
# Redis event bus (multi-host). Chon: true | false. Mac dinh: false.
# !!! bootstrap.mjs ep/canh bao =true khi COORDINATOR_ENABLE=true, vi luc handover
# luon la multi-host (Old + New overlap tren 2 runner) -> state can dong bo qua Redis.
DOCKFLARE_REDIS_ENABLE=false
# Ket noi Redis. Uu tien URL day du. Vd: redis://:password@redis-host:6379/0
DOCKFLARE_REDIS_URL=
DOCKFLARE_REDIS_HOST=redis
DOCKFLARE_REDIS_PORT=6379
DOCKFLARE_REDIS_PASSWORD=

# ------------------------------------------------------------------------------
# RESOLVE / RTDB (config & cache - luon bat)
# ------------------------------------------------------------------------------
# URL Google Realtime Database. Vd: https://<project>.firebaseio.com
RTDB_URL=
# Service account JSON Firebase. Co the dat `base64:<chuoi>` hoac raw JSON.
# Sau decode phai JSON.parse duoc moi chap nhan.
# Lay tai: Firebase console > Project settings > Service accounts.
RTDB_SERVICE_ACCOUNT=
# NAMESPACE RTDB (tach biet theo nghiep vu, KHONG dung chung root):
#   /stack/${STACK_ID}/coordinator/...    -> lock, heartbeat, handoff
#   /stack/${STACK_ID}/resolve-cache/...  -> accountId, key pool status
# Path cache local cho resolve (tier 1). Derive tu DOCKER_VOLUMES_DIR.
RESOLVE_CACHE_PATH=${DOCKER_VOLUMES_DIR}/.cache/resolve.json
# Path nhanh RTDB cho resolve-cache (tier 2). Derive tu STACK_ID.
RESOLVE_RTDB_PATH=/stack/${STACK_ID}/resolve-cache

# ------------------------------------------------------------------------------
# COORDINATOR (tuy chon - lifecycle handover chong restart 60 phut)
# ------------------------------------------------------------------------------
# Bat coordinator. Chon: true | false. Mac dinh: false.
COORDINATOR_ENABLE=false
# Node lock RTDB. Derive theo STACK_ID.
COORDINATOR_LOCK_PATH=/stack/${STACK_ID}/coordinator
# Chu ky heartbeat (giay). Nen < 1/3 SESSION_TTL. Mac dinh: 15.
COORDINATOR_HEARTBEAT_SEC=15
# TTL phien primary (giay). Mac dinh: 60.
COORDINATOR_SESSION_TTL_SEC=60
# Buffer kich hoat handover som truoc deadline job (giay). Vd job 60 phut, buffer
# 600 => bat dau handover o phut 50 de flush kip truoc khi runner SIGKILL.
COORDINATOR_HANDOVER_BUFFER_SEC=600
# Instance cu tu thoat khi cai moi ready (thay vi chi read-only).
# Chon: true | false. Mac dinh: false (read-only).
# LUU Y: neu false, node Tailscale ephemeral cua instance cu van song -> qua nhieu
# chu ky handover se tich tu. Xem COORDINATOR_MAX_OVERLAP.
COORDINATOR_OLD_AUTO_EXIT=false
# Gioi han so instance overlap toi da (canh bao/chan khi vuot). Mac dinh: 2.
COORDINATOR_MAX_OVERLAP=2
# CONTRACT READ-ONLY (OPT-IN): coordinator ghi file nay khi chuyen read-only;
# app phai TU check truoc khi ghi (import scripts/lib/readonly-guard.mjs). Xem README.
# Derive tu DOCKER_VOLUMES_DIR.
COORDINATOR_READONLY_FLAG_PATH=${DOCKER_VOLUMES_DIR}/.readonly

# ------------------------------------------------------------------------------
# RCLONE (tuy chon - sync bulk .docker-volumes)
# ------------------------------------------------------------------------------
# Bat rclone. Chon: true | false. Mac dinh: false.
RCLONE_ENABLE=false
# Cau hinh rclone: DUNG 1 TRONG 2 (khong gop chung).
#  - RCLONE_CONFIG_PATH: duong dan file rclone.conf co san (uu tien).
#  - RCLONE_CONFIG_CONTENT: noi dung rclone.conf (co the `base64:<chuoi>` hoac raw),
#    ghi ra file tam.
RCLONE_CONFIG_PATH=
RCLONE_CONFIG_CONTENT=
# Ten remote. Vd: gdrive
RCLONE_REMOTE=
# Path dich tren remote - derive tu STACK_ID. 2 stack cung path se ghi de nhau.
RCLONE_PATH=${STACK_ID}
# So luong transfer/checker song song. Mac dinh: 4.
RCLONE_TRANSFERS=4
RCLONE_CHECKERS=4
# LOAI TRU SQLite khoi rclone sync: bootstrap.mjs TU SINH tu LITESTREAM_DB_PATH
# (them -wal/-shm, dang pattern **/<db>). KHONG set tay o day de tranh lech voi
# LITESTREAM_DB_PATH. De trong; bootstrap se dien.
RCLONE_EXCLUDE=

# ------------------------------------------------------------------------------
# LITESTREAM (tuy chon - SQLite realtime -> S3 Supabase)
# ------------------------------------------------------------------------------
# Bat litestream. Chon: true | false. Mac dinh: false.
LITESTREAM_ENABLE=false
# Endpoint S3 Supabase. Lay tu supabase.com.database (phan S3Url).
LITESTREAM_S3_ENDPOINT=
LITESTREAM_S3_BUCKET=
# Lay tu supabase.com.database (AccessKeyID|SecretAccessKey).
LITESTREAM_S3_ACCESS_KEY_ID=
LITESTREAM_S3_SECRET_ACCESS_KEY=
# File SQLite can replicate. Derive tu DOCKER_VOLUMES_DIR. bootstrap se sinh
# RCLONE_EXCLUDE tu bien nay. litestream force-restore theo generation (khong
# chi -if-db-not-exists) de tranh dung DB cu tren self-hosted runner.
LITESTREAM_DB_PATH=${DOCKER_VOLUMES_DIR}/app.db

# ------------------------------------------------------------------------------
# TAILSCALE (tuy chon - mang noi bo)
# ------------------------------------------------------------------------------
# Bat tailscale. Chon: true | false. Mac dinh: false.
TAILSCALE_ENABLE=false
# OAuth client (tu tailscale.com.TrustCredentials). Adapter goi API lay ephemeral
# authkey roi set TS_AUTHKEY. Health-check OAuth: POST /api/v2/oauth/token.
# Lay tai: Tailscale admin > Settings > OAuth clients.
TAILSCALE_CLIENT_ID=
TAILSCALE_CLIENT_SECRET=
# Tags advertise (bat buoc khi OAuth). Adapter dich -> TS_EXTRA_ARGS=--advertise-tags=...
TAILSCALE_TAGS=tag:container
# Node ephemeral (tu don khi thoat). Chon: true | false. Mac dinh: true.
TAILSCALE_EPHEMERAL=true
# State dir. Derive tu DOCKER_VOLUMES_DIR. Adapter map -> TS_STATE_DIR.
TAILSCALE_STATE_DIR=${DOCKER_VOLUMES_DIR}/tailscale

# ------------------------------------------------------------------------------
# DOZZLE (tuy chon - log viewer realtime) - MODULE BAO MAT (fail-closed)
# ------------------------------------------------------------------------------
# Bat dozzle. Chon: true | false. Mac dinh: false.
DOZZLE_ENABLE=false
# Dia chi bind (image doc thang). Mac dinh: :8080
DOZZLE_ADDR=:8080
# Base path khi sau reverse proxy. Mac dinh: /
DOZZLE_BASE=/
# Auth provider. Chon: none | simple. Mac dinh: simple.
# !!! simple KHONG chi la env: can file /data/users.yml (password hash sha-256).
# bootstrap sinh users.yml bang `dozzle generate` tu DOZZLE_USERNAME/PASSWORD.
# FAIL-CLOSED: expose ma thieu credential -> khong start.
DOZZLE_AUTH_PROVIDER=simple
# Credential admin cho simple auth (bat buoc khi AUTH_PROVIDER=simple + expose).
DOZZLE_USERNAME=admin
DOZZLE_PASSWORD=
# Log level. Chon: debug | info | warn | error. Mac dinh: info.
DOZZLE_LEVEL=info
# Tat analytics. Chon: 0 | 1. Mac dinh: 1.
DOZZLE_NO_ANALYTICS=1

# ------------------------------------------------------------------------------
# FILEBROWSER (tuy chon - quan ly file volume) - MODULE BAO MAT (fail-closed)
# ------------------------------------------------------------------------------
# LUU Y: image doc bien FB_* - compose PHAI map tuong minh FB_PORT=${FILEBROWSER_PORT}
# ... neu khong container silent-fail dung default sai.
# Bat filebrowser. Chon: true | false. Mac dinh: false.
FILEBROWSER_ENABLE=false
# Cong lang nghe -> map FB_PORT. Mac dinh: 8081.
FILEBROWSER_PORT=8081
# THU MUC GOC TRONG CONTAINER -> map FB_ROOT. Day la path BEN TRONG container,
# KHONG phai path host. Bind ${DOCKER_VOLUMES_DIR} do compose volumes: lo. Mac dinh: /srv
FILEBROWSER_ROOT=/srv
# Base URL khi sau reverse proxy -> map FB_BASEURL. De trong neu khong dung.
FILEBROWSER_BASEURL=
# !!! Password admin (bat buoc khi enable). CI khong co nguoi doi qua UI, nen
# bootstrap chay `filebrowser config init` + `filebrowser users update admin
# --password <hash>` (hash bang `filebrowser hash`) TRUOC khi start process chinh
# (DB bi lock khi dang chay). DB phai persist trong volume (khong reset admin/admin).
# FAIL-CLOSED: rong ma ENABLE=true -> khong start.
FILEBROWSER_ADMIN_PASSWORD=

# ------------------------------------------------------------------------------
# TTYD / WEBSSH (tuy chon - terminal web) - MODULE BAO MAT (fail-closed)
# ------------------------------------------------------------------------------
# LUU Y: ttyd cau hinh bang CLI args, KHONG phai env. Entrypoint dung TOKENIZER
# string-argv de tach TTYD_CMD va bao credential, KHONG dung .split(' ') -> tranh injection.
# Bat ttyd. Chon: true | false. Mac dinh: false.
TTYD_ENABLE=false
# Cong lang nghe -> arg -p. Mac dinh: 7681.
TTYD_PORT=7681
# Basic auth user:pass -> arg -c. BAT BUOC neu TTYD_ENABLE.
# FAIL-CLOSED: rong ma ENABLE=true -> khong start. Vd: admin:changeme
TTYD_CREDENTIAL=
# Cho phep ghi -> arg -W. Chon: true | false. Mac dinh: true (WebSSH tuong tac that;
# neu false client khong go duoc lenh, smoke test whoami khong pass). false chi cho
# use-case xem thu dong.
TTYD_WRITABLE=true
# Lenh chay. Vd: bash | sh | ssh user@host. Mac dinh: bash.
TTYD_CMD=bash
# Gioi han client dong thoi -> arg --max-clients. Mac dinh: 1.
TTYD_MAX_CLIENTS=1
